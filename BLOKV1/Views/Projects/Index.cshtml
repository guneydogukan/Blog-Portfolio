@using BLOGV1.Models
@model List<Projects>

@{
    ViewData["Title"] = "Projects";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Sayfa Başlığı -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Projects</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">PROJECTS</h6>
        <p class="mb-0 small text-muted">
            Selections from the web applications, integration services and enterprise software projects I have implemented.
        </p>
        <div class="mt-3">
            <a asp-controller="Projects"
               asp-action="Create"
               class="btn btn-primary btn-sm shadow-sm">
                <i class="fas fa-plus fa-sm text-white-50"></i> New Project
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="container-fluid px-0" data-aos="fade-up">
            <div class="row gx-4 gy-4">

                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-4 mb-4">
                            <div class="card bg-white border-secondary shadow-sm h-100">

                                <!-- Proje görseli -->
                                <img src="@item.ProjectImageUrl"
                                     class="card-img-top w-100"
                                     style="height:200px; object-fit:cover;"
                                     alt="@item.ProjectName" />

                                <!-- Başlık + açıklama -->
                                <div class="card-body">
                                    <h5 class="card-title text-dark fw-bold">@item.ProjectName</h5>
                                    <p class="card-text text-secondary mb-0">
                                        @item.Description
                                    </p>
                                </div>

                                <!-- Alt kısım: footer + Details + 3 nokta dropdown -->
                                <div class="card-footer bg-transparent border-secondary d-flex justify-content-between align-items-center">
                                    <p class="mb-0 small text-secondary">
                                        @item.footer   @* örn: ASP.NET Core • SQL Server *@
                                    </p>

                                    <div class="d-flex align-items-center">

                                        <!-- Details butonu -->
                                        <a asp-controller="Details"
                                           asp-action="Edit"
                                           asp-route-projectid="@item.Id"
                                           class="btn btn-outline-dark btn-sm fw-semibold mr-2">
                                            Details
                                        </a>

                                        <!-- 3 nokta dropdown -->
                                        <div class="dropdown no-arrow">
                                            <a class="btn btn-light btn-sm border-0 dropdown-toggle"
                                               href="#"
                                               role="button"
                                               id="projectMenu_@item.Id"
                                               data-toggle="dropdown"
                                               aria-haspopup="true"
                                               aria-expanded="false">
                                                <i class="fas fa-ellipsis-v fa-sm text-muted"></i>
                                            </a>

                                            <div class="dropdown-menu dropdown-menu-right shadow animated--fade-in"
                                                 aria-labelledby="projectMenu_@item.Id">
                                                <h6 class="dropdown-header">Actions</h6>

                                                <!-- Edit -->
                                                <a class="dropdown-item"
                                                   asp-controller="Projects"
                                                   asp-action="Edit"
                                                   asp-route-id="@item.Id">
                                                    Edit
                                                </a>
                                            
                                                <div class="dropdown-divider"></div>

                                                <!-- Delete (POST) -->
                                                <form asp-controller="Projects"
                                                      asp-action="Delete"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="px-3"
                                                      onsubmit="return confirm('Bu projeyi silmek istediğinize emin misiniz?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-link p-0 text-danger">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-info mb-0">
                            Şu anda listelenecek proje bulunmamaktadır.
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

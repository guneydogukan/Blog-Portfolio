<section id="contact" class="contact-section py-5">
    <div class="container py-4">
        <div class="row g-4 align-items-stretch">

            
            @await Component.InvokeAsync("_ContactMeComponentPartial")

           
            <div class="col-12 col-lg-7">
                <div class="card contact-form-card h-100 shadow-sm border-0">
                    <div class="card-body p-4 p-lg-5">

                        <h3 class="fw-bold mb-4">Contact Me</h3>

                        <form asp-action="Mesaj" asp-controller="Blogs" method="post">
                            <div class="mb-3">
                                <input name="nameSurname" type="text" class="form-control form-control-lg"
                                       placeholder="Name Surname">
                            </div>

                            <div class="mb-3">
                                <input name="email" type="email" class="form-control form-control-lg"
                                       placeholder="Email">
                            </div>

                            <div class="mb-4">
                                <textarea name="messages" rows="5" class="form-control form-control-lg"
                                          placeholder="Your message"></textarea>
                            </div>

                            <button type="submit" class="btn btn-accent btn-lg w-100 rounded-pill fw-bold">
                                Submit
                            </button>
                        </form>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


@model About
    <section id="about" class="about section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row gy-4">
              <div class="col-md-6">

                    <div class="row justify-content-between gy-4">
                        <div class="col-lg-5">
                            <img src="@Model.ProfileImageUrl" class="img-fluid" alt="">
                        </div>
                        <div class="col-lg-7 about-info">
                            <p><strong>Name: </strong> <span>@Model.Name</span></p>
                            <p><strong>Profession: </strong> <span>@Model.Profession</span></p>
                            <p><strong>Email: </strong> <span>@Model.Email</span></p>
                            <p><strong>Phone: </strong> <span>@Model.Phone</span></p>
                        </div>
                    </div>
                    @await Component.InvokeAsync("_SkillsComponentPartial")
                    
                </div>

                <div class="col-md-6">
                    <div class="about-me">
                        <h4>About Me</h4>
                        <p>
                            @Model.AboutMe
                        </p>

                    </div>
                </div>
            

            </div>

        </div>

    </section>
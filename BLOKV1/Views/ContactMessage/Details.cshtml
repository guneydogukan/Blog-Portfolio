@using BLOGV1.Models
@model Message

@{
    ViewData["Title"] = "Message Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Sayfa Başlığı -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Contact Message Details</h1>

    <a asp-controller="ContactMessage"
       asp-action="Index"
       class="btn btn-sm btn-secondary">
        ← Back to List
    </a>
</div>

<!-- Ana Kart -->
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            Message from @Model.NameSurname
        </h6>

        <span class="small text-muted">
            @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
        </span>
    </div>

    <div class="card-body">

        
        <div class="row mb-4">
            <div class="col-md-6">
                <p class="mb-2">
                    <strong>Name Surname:</strong>
                    <span class="text-secondary">@Model.NameSurname</span>
                </p>
                <p class="mb-2">
                    <strong>Email:</strong>
                    <span class="text-secondary">@Model.Email</span>
                </p>
            </div>

            <div class="col-md-6">
                <p class="mb-2">
                    <strong>Date:</strong>
                    <span class="text-secondary">
                        @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </span>
                </p>
            </div>
        </div>

        <hr />

        
        <div class="mb-4">
            <h5 class="mb-3">Message</h5>
            <div class="border rounded p-3 bg-light" style="white-space:pre-line;">
                @Model.Messages
            </div>
        </div>

       
        <div class="d-flex justify-content-between mt-4">

            <a asp-controller="ContactMessage"
               asp-action="Index"
               class="btn btn-outline-secondary">
                ← Back to Messages
            </a>

            <form asp-controller="ContactMessage"
                  asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post"
                  onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
            </form>
        </div>

    </div>
</div>

@using BLOGV1.Models
@model List<Message>  
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Contact Messages</h1>
</div>


<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <div>
            <h6 class="m-0 font-weight-bold text-primary">Contact Messages</h6>
        </div>
    </div>

    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>NameSurname</th>
                            <th>Email</th>
                            <th style="width: 30%;">Message</th>
                            <th style="width: 150px;">Date</th>
                            <th style="width: 100px;">Actions</th>
                            
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var index = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.NameSurname</td>
                                <td>@item.Email</td>

                                
                                <td>
                                    @{
                                        var text = item.Messages;
                                        if (!string.IsNullOrWhiteSpace(text) && text.Length > 80)
                                        {
                                            text = text.Substring(0, 80) + "...";
                                        }
                                    }
                                    @text
                                </td>

                                <td>
                                    @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td class="text-right">

                                    
                                    <div class="mb-2">
                                        <a asp-controller="ContactMessage"
                                           asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Details
                                        </a>
                                    </div>

                                   
                                    <div>
                                        <form asp-controller="ContactMessage"
                                              asp-action="Delete"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm btn-danger">
                                                Delete
                                            </button>
                                        </form>
                                    </div>

                                </td>

                            </tr>

                            index++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                Şu anda görüntülenecek mesaj bulunmamaktadır.
            </div>
        }
    </div>
</div>

@using BLOGV1.Identity
@model BLOGV1.Models.ViewModels.UserEditViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Profil Bilgilerim</h1>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Bilgileri Düzenle</h6>
                </div>
                <div class="card-body">
                    <form method="post">

                        <div class="form-group row">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <label>Ad</label>
                                <input type="text" asp-for="Name" class="form-control form-control-user" placeholder="Adınız">
                            </div>
                            <div class="col-sm-6">
                                <label>Soyad</label>
                                <input type="text" asp-for="Surname" class="form-control form-control-user" placeholder="Soyadınız">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Email Adresi</label>
                            <input type="email" asp-for="Email" class="form-control form-control-user" placeholder="Email Adresi">
                        </div>

                        @* <div class="form-group">
                            <label>Telefon Numarası</label>
                            <input type="text" asp-for="PhoneNumber" class="form-control form-control-user" placeholder="Telefon (Opsiyonel)">
                        </div> *@

                        <hr>
                        <p class="text-muted small">Şifrenizi değiştirmek istemiyorsanız aşağıdaki alanları boş bırakın.</p>

                        <div class="form-group row">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <input type="password" asp-for="Password" class="form-control form-control-user" placeholder="Yeni Şifre">
                            </div>
                            <div class="col-sm-6">
                                <input type="password" asp-for="ConfirmPassword" class="form-control form-control-user" placeholder="Şifre Tekrar">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-user btn-block">
                            Güncelle
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
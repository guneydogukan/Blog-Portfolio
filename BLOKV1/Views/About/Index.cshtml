@using BLOGV1.Models
@model About

@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">About</h1>
</div>
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <div>
            <h6 class="m-0 font-weight-bold text-primary">ABOUT INFORMATION</h6>     
        </div>

        <a asp-controller="About"
           asp-action="Edit"
           asp-route-id="@Model?.Id"
           class="btn btn-primary btn-sm">
            <i class="fas fa-edit fa-sm text-white-50"></i> Edit About
        </a>
    </div>

    <div class="card-body">
        @if (Model != null)
        {
            <div class="row gy-4">

                <div class="col-md-6">

                    <div class="row justify-content-between gy-4 mb-4">
                        <div class="col-lg-5">
                            <img src="@Model.ProfileImageUrl"
                                 class="img-fluid rounded shadow-sm"
                                 style="object-fit:cover; max-height:260px;"
                                 alt="@Model.Name" />
                        </div>

                        <div class="col-lg-7 about-info">
                            <p><strong>Name: </strong> <span>@Model.Name</span></p>
                            <p><strong>Profession: </strong> <span>@Model.Profession</span></p>
                            <p><strong>Email: </strong> <span>@Model.Email</span></p>
                            <p><strong>Phone: </strong> <span>@Model.Phone</span></p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="about-me">
                        <h4>About me</h4>
                        <hr class="mt-1 mb-3" />
                        <p style="white-space:pre-line;">
                            @Model.AboutMe
                        </p>
                    </div>
                </div>

            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                Şu anda görüntülenecek bir About kaydı bulunmamaktadır.
            </div>
        }
    </div>
</div>


@using BLOGV1.Models

@model Contact

<div class="col-12 col-lg-5">
    <div class="card contact-info-card h-100 shadow-sm border-0">
        <div class="card-body p-4 p-lg-5">

            <h3 class="fw-bold mb-4">Contact</h3>

            <div class="d-flex gap-3 mb-4">
                <div class="icon-chip">
                    <i class="bi bi-telephone"></i>
                </div>
                <div>
                    <div class="fw-semibold">Phone</div>
                    <div class="text-muted small">@Model.Phone</div>

                </div>
            </div>

            <div class="d-flex gap-3 mb-4">
                <div class="icon-chip">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <div>
                    <div class="fw-semibold">Address</div>
                    <div class="text-muted small">
                        @Model.Address
                    </div>
                </div>
            </div>

            
            <div class="d-flex gap-3">
                <div class="icon-chip">
                    <i class="bi bi-share"></i>
                </div>
                <div>
                    <div class="fw-semibold">Sosyal Medya</div>

                    @if (!string.IsNullOrEmpty(Model.Instagram))
                    {
                        <div class="text-muted small">
                            <a href="@Model.Instagram" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-instagram"></i> Instagram
                            </a>
                        </div>
                    }

                 
                    @if (!string.IsNullOrEmpty(Model.Twitter))
                    {
                        <div class="text-muted small">
                            <a href="@Model.Twitter" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-twitter-x"></i> X (Twitter)
                            </a>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.LinkedIn))
                    {
                        <div class="text-muted small">
                            <a href="@Model.LinkedIn" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-linkedin"></i> LinkedIn
                            </a>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
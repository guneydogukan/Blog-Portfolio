@using BLOGV1.Models
@model List<Skill>

<div class="skills-content skills-animation">

    <h5>Skills</h5>
    @foreach(var item in Model)
    {
        <div class="progress">
            <span class="skill"><span>@item.SkillName</span> <i class="val">@item.ProficiencyPercentage%</i></span>
            <div class="progress-bar-wrap">
                <div class="progress-bar" role="progressbar" aria-valuenow="@item.ProficiencyPercentage" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        </div>
    }
    
</div>